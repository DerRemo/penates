PORT=3333
AUTH_TOKEN=
SESSION_PREFIX=cc-
DEFAULT_PROJECT_DIR=~
TMUX_PATH=/opt/homebrew/bin/tmux
PROJECT_ROOTS=~/Projects
# Allow-List für /api/browse und neue Projekte (`:`-getrennt, `~` erlaubt).
# Default: nur $HOME. Beispiel: BROWSE_ROOTS=~/Projects:/Volumes/SSD/code
BROWSE_ROOTS=

# Web Push VAPID-Keys (auto-generiert beim ersten Server-Start wenn leer)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=https://deine-domain.tld  # Apple Web Push verlangt echte Domain (kein localhost)
