PORT=3333
AUTH_TOKEN=
SESSION_PREFIX=cc-
DEFAULT_PROJECT_DIR=~
# Optional: Override tmux path (auto-detected via `which tmux` if omitted)
# TMUX_PATH=/opt/homebrew/bin/tmux
# Optional: tmux mouse-mode. Default `on` (Scroll-Wheel im Hub-Terminal).
# Auf `off` setzen, wenn primär über Moshi/mobile Terminals gearbeitet wird —
# der globale Mouse-Mode stört dort native Touch-Selektion. tmux Mouse ist
# server-global, nicht per-Client.
# TMUX_MOUSE=on
PROJECT_ROOTS=~/Projects
# Allow-List für /api/browse und neue Projekte (`:`-getrennt, `~` erlaubt).
# Default: nur $HOME. Beispiel: BROWSE_ROOTS=~/Projects:/Volumes/SSD/code
BROWSE_ROOTS=

# Browser-Preview: Wildcard-Subdomain für den Dev-Server-Reverse-Proxy.
# Leer lassen = Feature aus. Beispiel: PREVIEW_DOMAIN=hub.example.com →
# Dev-Server erreichbar unter https://<port>.preview.hub.example.com/.
# Erfordert Wildcard-DNS (*.preview.<domain>) + dieselbe CF-Access-Policy
# wie der Hub. setup.sh führt durch die Einrichtung.
PREVIEW_DOMAIN=

# Web Push VAPID-Keys (auto-generiert beim ersten Server-Start wenn leer)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=https://deine-domain.tld  # Apple Web Push verlangt echte Domain (kein localhost)

# Cloudflare Access JWT-Validation (optional). Leer lassen = disabled,
# Server läuft im Bearer-only-Modus (wie v0.4.0 und früher). Beide
# gesetzt = secureMiddleware fordert zusätzlich ein gültiges JWT vom
# Cf-Access-Jwt-Assertion-Header auf Tunnel-Requests (erkannt an Cf-Ray).
# Team-Domain und Application-Audience-Tag kommen aus dem Cloudflare-
# Zero-Trust-Dashboard (Access → Applications → <deine-App>).
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ── Voice-Input (lokale whisper.cpp-Transkription) ──
# Auto-deaktiviert, wenn WHISPER_BIN oder WHISPER_MODEL fehlen.
# VOICE_ENABLED=false   # hart abschalten (sonst abgeleitet aus bin+model)
# WHISPER_BIN=/opt/homebrew/bin/whisper-cli
# WHISPER_MODEL=~/.claude-code-hub/models/ggml-large-v3-turbo-q5_0.bin
VOICE_LANG=de
